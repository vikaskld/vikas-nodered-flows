    {
        "id": "b35b416017d0e55f",
        "type": "function",
        "z": "bf01f7e86a4f7388",
        "name": "Humidity",
        "func": "// Pehle se saved value ko read karein ya 50.0 se start karein\nlet currentHumid = context.get('currentHumid') || 50.0;\n\n// Randomly value ko thoda badhayein ya ghatayein (-0.5 se +0.5 ke beech)\nlet change = (Math.random() - 0.5) * 1.0;\ncurrentHumid += change;\n\n// Limit set karein taaki humidity 40% se 80% ke beech hi rahe\nif (currentHumid < 40) currentHumid = 40;\nif (currentHumid > 80) currentHumid = 80;\n\n// Value save karein agli baar ke liye\ncontext.set('currentHumid', currentHumid);\nmsg.load=\"humidity\";\nmsg.payload = parseFloat(currentHumid.toFixed(2));\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 600,
        "wires": [
            [
                "9bc99bfc491b9b56",
                "606f2c806ef796b9"
            ]
        ]
    },
    {
        "id": "a35630dd8f8c3cf4",
        "type": "function",
        "z": "bf01f7e86a4f7388",
        "name": "Power",
        "func": "// Base power 5.0 kW, isme random spikes add karenge\nlet basePower = 5.0;\nlet fluctuation = Math.random() * 3.5; // 0 se 3.5 kW ka variation\n\nlet totalPower = basePower + fluctuation;\nmsg.topic=\"power\";\nmsg.payload = parseFloat(totalPower.toFixed(2));\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 410,
        "y": 400,
        "wires": [
            [
                "9bc99bfc491b9b56",
                "2c2aa50dcee4ddf9"
            ]
        ]
    },
    {
        "id": "aed331f09ca90772",
        "type": "function",
        "z": "bf01f7e86a4f7388",
        "name": "Vibration",
        "func": "// Vibration (g-force) jo har second bohot tezi se badal raha hai\nlet minVib = 0.1;\nlet maxVib = 2.5;\nlet vibration = Math.random() * (maxVib - minVib) + minVib;\nmsg.topic=\"Vibration\";\nmsg.payload = parseFloat(vibration.toFixed(3)); // 3 decimal places tak\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
