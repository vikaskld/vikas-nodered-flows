    {
        "id": "bdc559e30c73e5ca",
        "type": "function",
        "z": "bf01f7e86a4f7388",
        "name": "Floating Data Generator",
        "func": "// 20.00 se 35.00 ke beech random floating value generate karne ke liye\nlet min = 20.0;\nlet max = 35.0;\nlet randomFloat = Math.random() * (max - min) + min;\n\n// Decimal ke baad sirf 2 digits rakhne ke liye (e.g., 26.45)\nmsg.payload = parseFloat(randomFloat.toFixed(2)); \n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 490,
        "y": 80,
